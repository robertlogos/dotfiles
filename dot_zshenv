# Zsh gimmick to easen $PATH management
typeset -U path
path+=(
 "${HOME}/.local/bin"
 "${HOME}/.cargo/bin"
 "${HOME}/.crc/bin/oc"
)
export PATH

export EDITOR=vim


# homebrew
if [[ -f "/opt/homebrew/bin/brew" ]] then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# asdf
. /opt/homebrew/opt/asdf/libexec/asdf.sh

